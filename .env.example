# ──────────────────────────────────────────────────────────────────
# Portal — environment template. Copy to `.env` and fill in.
# ──────────────────────────────────────────────────────────────────

# General
APP_ENV=development                 # development | staging | production
APP_DOMAIN=portal.localhost         # base domain (Traefik routes use this)
LOG_LEVEL=debug                     # debug | info | warn | error

# ── Postgres ──────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=portal
POSTGRES_USER=portal
POSTGRES_PASSWORD=change-me
# Used by API/worker — usually points at PgBouncer in prod
DATABASE_URL=postgres://portal:change-me@pgbouncer:6432/portal?sslmode=disable

# ── PgBouncer ─────────────────────────────────────────────────────
PGBOUNCER_POOL_MODE=transaction
PGBOUNCER_MAX_CLIENT_CONN=200
PGBOUNCER_DEFAULT_POOL_SIZE=25

# ── DragonflyDB (Redis-compatible) ────────────────────────────────
REDIS_URL=redis://dragonfly:6379/0
ASYNQ_REDIS_URL=redis://dragonfly:6379/1

# ── MinIO (S3-compatible) ─────────────────────────────────────────
MINIO_ROOT_USER=portal
MINIO_ROOT_PASSWORD=change-me
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=portal-media
S3_ACCESS_KEY=portal
S3_SECRET_KEY=change-me
S3_USE_PATH_STYLE=true              # required for MinIO

# ── Cloudflare R2 (production CDN origin) ─────────────────────────
R2_ENDPOINT=
R2_ACCOUNT_ID=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=

# ── Authentik (OIDC) ──────────────────────────────────────────────
OIDC_ISSUER=https://auth.portal.localhost/application/o/portal/
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URL=https://portal.localhost/auth/callback

# ── API ───────────────────────────────────────────────────────────
API_PORT=8080
API_BASE_URL=https://api.portal.localhost

# ── JWT signing keys (rotating) ────────────────────────────────────
# Format: kid:base64-secret[,kid:base64-secret...]
# First key is the active signer; later keys remain valid for verification
# during a rotation grace window. Generate with:
#   openssl rand -base64 48 | tr -d '\n'
JWT_SIGNING_KEYS=v1:CHANGE-ME-base64-encoded-32-or-more-bytes
JWT_ISSUER=portal
JWT_AUDIENCE=portal-api
ACCESS_TOKEN_TTL=5m
REFRESH_TOKEN_TTL=720h
PERMISSION_CACHE_TTL=5m

# ── Cookies ────────────────────────────────────────────────────────
COOKIE_DOMAIN=
COOKIE_SECURE=true                 # set to false ONLY for plain-http dev
POST_LOGIN_URL=/

# ── Frontend ──────────────────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=https://api.portal.localhost
NEXT_PUBLIC_APP_NAME=Portal

# ── Traefik ───────────────────────────────────────────────────────
ACME_EMAIL=admin@portal.localhost
TRAEFIK_DASHBOARD_AUTH=admin:$apr1$change-me                # htpasswd format

# ── Observability ─────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me
GLITCHTIP_DSN=
